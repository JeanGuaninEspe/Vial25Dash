---
import "../styles/global.css"
import { LoginForm } from "../components/login-form"
import { Toaster } from "@/components/ui/sonner"
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/cropped-isotipo-32x32.webp" />
    <title>Ingresar - Sistema de Peajes</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="relative min-h-screen flex flex-col">
      <div class="absolute inset-0 bg-[url('/fondo.webp')] bg-cover bg-center" />
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900/50 via-slate-800/30 to-emerald-900/40" />
      <div class="relative z-10 flex flex-1 items-center justify-center px-4 py-12">
        <div class="grid w-full max-w-[960px] gap-8 lg:grid-cols-[1.1fr_1fr]">
          <div class="flex flex-col justify-center text-white pt-10">
            <h1 class="text-4xl font-semibold leading-tight">Sistema Integral de Peajes</h1>
            <p class="mt-3 text-base text-white/80">
              Analitica, recaudacion y control en tiempo real para la operacion vial.
            </p>
            <div class="mt-8 grid gap-4">
              <div class="group relative rounded-xl border border-white/10 bg-black/20 p-5 shadow-2xl backdrop-blur-md transition-all hover:bg-black/30 hover:border-emerald-500/30">
                <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
                <h3 class="text-base font-semibold text-emerald-300">Monitoreo de tráfico</h3>
                <p class="mt-1 text-sm text-white/70">Visualiza tendencias por cabina, turno y método de pago en tiempo real.</p>
              </div>
              <div class="group relative rounded-xl border border-white/10 bg-black/20 p-5 shadow-2xl backdrop-blur-md transition-all hover:bg-black/30 hover:border-emerald-500/30">
                <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
                <h3 class="text-base font-semibold text-emerald-300">Reportes inteligentes</h3>
                <p class="mt-1 text-sm text-white/70">KPIs claros para decisiones rápidas, seguras y eficientes.</p>
              </div>
            </div>
          </div>
          <div class="flex flex-col items-center gap-4">
            <div class="flex items-center gap-3">
              <img src="/LOGO-COSAD25.webp" alt="Logo COSAD" class="h-24 w-auto" />
            </div>
            <LoginForm client:only="react" />
          </div>
        </div>
      </div>
      <footer class="relative z-10 border-t border-white/20 bg-white/10 px-4 py-4 text-xs text-white/80">
        <div class="mx-auto flex w-full max-w-[960px] flex-col gap-2 md:flex-row md:items-center md:justify-between">
          <span>Desarrollado: Febrero 2026 · Jean Guanin</span>
          <span>© 2026 Sistema Integral de Peajes. Todos los derechos reservados.</span>
        </div>
      </footer>
    </div>
    <Toaster client:only="react" />
  </body>
</html>
