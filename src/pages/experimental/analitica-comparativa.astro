---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SidebarLayout } from '../../components/sidebar-layout';
import { AnaliticaComparativaDashboard } from '../../components/ui/analitica-comparativa-dashboard';
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/webp" href="/cropped-isotipo-32x32.webp" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		<title>Analítica Comparativa</title>
	</head>

	<body class="bg-background text-foreground antialiased">
		<SidebarLayout transition:persist
			client:load
			title="Analítica Comparativa"
			description="Compara el rendimiento de peajes entre dos períodos mensuales."
		>
			<AnaliticaComparativaDashboard client:only="react" />
		</SidebarLayout>
	</body>
</html>