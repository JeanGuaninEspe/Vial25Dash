---
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SidebarLayout } from '../../components/sidebar-layout';
import { RecaudacionSemanalExperimental } from '../../components/ui/recaudacion-semanal-experimental';
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/cropped-isotipo-32x32.webp" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		<title>Recaudación Semanal (Experimental) - Sistema Peajes</title>
	</head>

	<body class="bg-background text-foreground antialiased">
		<SidebarLayout transition:persist
			client:load
			title="Recaudación Semanal (Experimental)"
			description="Reporte semanal con KPIs y gráfico, acotado al periodo disponible"
		>
			<RecaudacionSemanalExperimental client:load />
		</SidebarLayout>
	</body>
</html>

