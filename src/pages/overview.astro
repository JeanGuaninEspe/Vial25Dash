---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SidebarLayout } from '../components/sidebar-layout';
import { OverviewDashboard } from '../components/ui/overview-dashboard';
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/webp" href="/cropped-isotipo-32x32.webp" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		<title>Overview - Recaudación Peajes</title>
	</head>

	<body class="bg-background text-foreground antialiased">
		<SidebarLayout transition:persist 
			client:load
			title="Visión General"
			description="Resumen de tráfico y recaudación del sistema."
		>
			<OverviewDashboard client:load />
		</SidebarLayout>
	</body>
</html>
