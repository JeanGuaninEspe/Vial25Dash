---
import "../styles/global.css"
import { ClientRouter } from 'astro:transitions';
import { SidebarLayout } from "../components/sidebar-layout"
import { DescuentosRfidAdmin } from "../components/ui/descuentos-rfid-admin"
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/cropped-isotipo-32x32.webp" />
    <meta name="generator" content={Astro.generator} />
		<ClientRouter />
    <title>Descuentos RFID - Sistema de Peajes</title>
  </head>

  <body class="bg-background text-foreground antialiased">
    <SidebarLayout transition:persist client:load title="Descuentos RFID" description="Gestion y seguimiento de autorizaciones RFID">
      <DescuentosRfidAdmin client:only="react" />
    </SidebarLayout>
  </body>
</html>

